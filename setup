#!/usr/bin/env bash
# namejam setup — register the /namejam slash command after cloning.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# ─── Detect install location ─────────────────────────────────
# Global: ~/.claude/skills/namejam/
# Local:  .claude/skills/namejam/ (inside a project repo)
COMMANDS_DIR=""
if [[ "$SCRIPT_DIR" == "$HOME/.claude/skills/namejam" ]]; then
  COMMANDS_DIR="$HOME/.claude/commands"
  SKILL_PATH="~/.claude/skills/namejam/SKILL.md"
  echo "Detected: global install at ~/.claude/skills/namejam/"
elif [[ "$SCRIPT_DIR" == *".claude/skills/namejam" ]]; then
  REPO_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"
  COMMANDS_DIR="$REPO_ROOT/.claude/commands"
  SKILL_PATH=".claude/skills/namejam/SKILL.md"
  echo "Detected: project-local install"
else
  # Running from a direct clone (e.g., user cloned into ~/namejam)
  echo "Detected: standalone clone at $SCRIPT_DIR"
  echo "The /namejam command works automatically from this directory."
  echo ""
  echo "For global install (works in any project):"
  echo "  git clone https://github.com/FireflySentinel/namejam.git ~/.claude/skills/namejam"
  echo "  cd ~/.claude/skills/namejam && ./setup"
  exit 0
fi

# ─── Create commands directory ────────────────────────────────
mkdir -p "$COMMANDS_DIR"

# ─── Write the command pointer ────────────────────────────────
cat > "$COMMANDS_DIR/namejam.md" << EOF
---
description: Generate available project names with taste — checks GitHub, npm, PyPI, and domain availability
---

Read and follow the instructions in $SKILL_PATH
EOF

echo "Created $COMMANDS_DIR/namejam.md"

# ─── Copy the update command ──────────────────────────────────
cp "$SCRIPT_DIR/.claude/commands/namejam-update.md" "$COMMANDS_DIR/namejam-update.md"
echo "Created $COMMANDS_DIR/namejam-update.md"

# ─── Create state directory ──────────────────────────────────
mkdir -p "$HOME/.namejam"

echo ""
echo "Done! Two commands are now available in Claude Code:"
echo "  /namejam        — generate project names"
echo "  /namejam-update — check for updates"
